# Base URL the openapi-fetch client calls.
# Default "/api" is a relative path that Vite proxies to the backend in dev
# (see vite.config.ts). In production point this at a same-origin proxy, or at
# the backend directly once it serves CORS headers.
VITE_API_BASE_URL=/api

# Where the Vite dev proxy forwards "/api" requests during `npm run dev`.
VITE_API_PROXY_TARGET=http://backen-loadb-j1ck0azqzxit-200572918.eu-central-1.elb.amazonaws.com
